{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__user_prompt_submit.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__stop.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
