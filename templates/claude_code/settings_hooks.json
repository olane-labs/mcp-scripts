{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__user_prompt_submit.sh",
            "timeout": 8,
            "statusMessage": "Querying context layer..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__permission_request.sh",
            "timeout": 5,
            "statusMessage": "Enriching permission context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__post_tool_use.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .olane/hooks/olane-copass__stop.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
